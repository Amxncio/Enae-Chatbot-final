# Groq API key — get yours free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Calendly PAT — used only for availability checking (read-only)
CALENDLY_TOKEN=your_calendly_pat_here
CALENDLY_USER_URI=https://api.calendly.com/users/your_user_uuid
CALENDLY_EVENT_TYPE_CAT_URI=https://api.calendly.com/event_types/your_cat_event_type_uuid
CALENDLY_EVENT_TYPE_DOG_URI=https://api.calendly.com/event_types/your_dog_event_type_uuid

# Google Calendar — used to CREATE the booking event directly in the clinic calendar
# Option A (local): put the JSON at docs/molten-reach-485011-b2-3bbf6b15204e.json (gitignored)
# Option B: path relative to repo root
# GOOGLE_SERVICE_ACCOUNT_FILE=docs/molten-reach-485011-b2-3bbf6b15204e.json
# Option C (Vercel): paste the full JSON as one line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Share the clinic calendar with the service account email (Editor role):
#   enae-vet@molten-reach-485011-b2.iam.gserviceaccount.com
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
